# ── Get your FREE Groq API key at: https://console.groq.com ──
GROQ_API_KEY=your_groq_api_key_here

# ── Git settings ──
GIT_BRANCH=main
GIT_REMOTE=origin

# ── Improvement target: backend | frontend | both ──
IMPROVE_TARGET=both

# ── Set to true to skip the random delay (for testing) ──
SKIP_DELAY=false

# ── Flask port ──
PORT=5000
